# agents@0.17.1 declares react@^19.0.0 as a peer dependency (for its frontend hooks).
# We only use the server-side McpAgent class (agents/mcp), which has no React runtime
# dependency. legacy-peer-deps lets npm install without upgrading React to v19.
# Re-evaluate when bumping the 'agents' package; run 'npm ls --depth=0' to audit new peer conflicts
legacy-peer-deps=true
