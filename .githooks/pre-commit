#!/usr/bin/env sh
# .githooks/pre-commit — openinspection
#
# Quality gate for commits made inside this repo. Activated automatically by the
# "prepare" npm script on `npm install`/`npm ci`:
#     git config core.hooksPath .githooks
# Bypass (discouraged): git commit --no-verify
#
# Mechanism is .githooks + core.hooksPath (no husky), aligned with the
# superproject and the portal/cms submodules.

# Never run in CI / non-interactive contexts (CI does not commit, but guard anyway).
[ -n "$CI" ] && exit 0

# Memory ceiling so concurrent pre-commits (two parallel agent sessions on this
# machine) don't exhaust RAM and freeze the box. Local-only (CI exited above).
# `:-` keeps any value the caller already exported.
#   NODE_OPTIONS → bound the node heavy steps: tsc type-check (--max-old-space-size
#                  is also set per-script), react-router build for the bundle-size
#                  gate, jscpd for lint:dup, eslint.
case " $NODE_OPTIONS " in *"--max-old-space-size"*) : ;; *) export NODE_OPTIONS="${NODE_OPTIONS:+$NODE_OPTIONS }--max-old-space-size=4096" ;; esac

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

FAILED=0

# printf, not echo: POSIX sh echo does not interpret \n or \033 escapes
# (they printed literally under Git Bash), and %b expands them portably.
pass() { printf '  ✓  %b\n' "$1"; }
fail() { printf '  ✗  %b\n' "$1"; FAILED=1; }
step() { printf '\n  →  %b\n' "$1"; }

printf '%b\n' "${BOLD}── OpenInspection (Pre-commit Checks) ───────────────────────────${NC}"

# 1. Type check — SCOPED to what the staged changes can actually affect.
#    Runs tsc (the SAME compiler as CI's authoritative "verify" gate) with
#    --incremental build-info caching, so a warm commit only re-checks what
#    changed and stays fast. (We used tsgo/@typescript/native-preview here before;
#    it was faster cold but unstable under memory pressure — GC death-loops that
#    timed out and left multi-GB zombies. tsc is bounded and predictable.)
#    Tiers:
#      - no staged .ts/.tsx or ts-config files  → skip type check entirely
#        (docs, assets, hooks, fixtures — a markdown edit must not cost seconds)
#      - staged TS confined to server/          → api pass only (type-check:api)
#      - anything touching app/ workers/ packages/ or ts-config files → full (type-check)
STAGED=$(git diff --cached --name-only --diff-filter=ACMRD)
TS_STAGED=$(echo "$STAGED" | grep -E '\.(ts|tsx)$' || true)
CONFIG_STAGED=$(echo "$STAGED" | grep -E '^(tsconfig|package\.json|package-lock\.json|vite\.config|react-router\.config|worker-configuration)' || true)

step "Type check"
if [ -z "$TS_STAGED" ] && [ -z "$CONFIG_STAGED" ]; then
    pass "Skipped — no staged TypeScript/config changes (CI verify remains the full gate)"
elif [ -z "$CONFIG_STAGED" ] && [ -z "$(echo "$TS_STAGED" | grep -vE '^(server|tests)/')" ]; then
    if npm run type-check:api > /dev/null 2>&1; then
        pass "Type check passed (tsc, api pass only — staged TS confined to server/ and tests/)"
    else
        fail "Type check failed  →  npm run type-check:api"
    fi
else
    if npm run type-check > /dev/null 2>&1; then
        pass "Type check passed (tsc)"
    else
        fail "Type check failed  →  npm run type-check"
    fi
fi

# 2. Lint & Fix
step "Lint & Fix"
if npx lint-staged; then
    pass "Lint & Fix passed"
else
    fail "Lint failed  →  npx lint-staged"
fi

# 3. Design System token conformance (fast full-repo scan; also gated in CI via npm run lint)
step "DS token conformance"
if node scripts/check-ds-tokens.mjs > /dev/null 2>&1; then
    pass "DS token conformance passed"
else
    fail "DS token check failed  →  npm run lint:ds"
fi

# 3a-svg. SVG-dimensions guardrail — every public SVG must declare intrinsic
#     width + height so an <img src=*.svg> never FOUC-flashes at ~300px before
#     CSS loads (also gated in CI via npm run lint).
step "SVG dimensions"
if node scripts/check-svg-dimensions.mjs > /dev/null 2>&1; then
    pass "SVG dimensions passed"
else
    fail "SVG-dimensions check failed  →  npm run lint:svg"
fi

# 3b. Migration-reference hygiene — no dangling migration sequence numbers in
#     comments (fast full-repo scan; also gated in CI via npm run lint).
step "Migration-reference hygiene"
if node scripts/check-migration-refs.mjs > /dev/null 2>&1; then
    pass "Migration-reference hygiene passed"
else
    fail "Migration-reference check failed  →  npm run lint:migrefs"
fi

# 3c. Large-file ratchet — no new files over the size limit; grandfathered
#     monoliths may not grow (fast full-repo scan; also gated in CI via npm run lint).
step "Large-file ratchet"
if node scripts/check-file-size.mjs > /dev/null 2>&1; then
    pass "Large-file ratchet passed"
else
    fail "Large-file gate failed  →  npm run lint:filesize"
fi

# 3d. Duplicate-code ceiling — copy/paste duplication must stay under the jscpd
#     threshold (also gated in CI via npm run lint).
step "Duplicate-code ceiling"
if npm run lint:dup > /dev/null 2>&1; then
    pass "Duplicate-code ceiling passed"
else
    fail "Duplicate-code gate failed  →  npm run lint:dup"
fi

# NOTE: the Worker bundle-size gate lives in .githooks/pre-push, not here. The
#    bundle can only break at deploy, and its check runs the REAL build pipeline
#    (~1-2 min), so paying it on every commit was overkill. pre-push builds it
#    once per push instead; CI's verify remains the authoritative final gate.

if [ "$FAILED" -eq 1 ]; then
    printf '\n%b\n' "${RED}Pre-commit checks failed. Fix the errors before committing.${NC}"
    exit 1
fi

printf '\n%b\n' "${GREEN}All pre-commit checks passed.${NC}"
exit 0
