# OpenInspection Frontend Worker config template.
#
# Copy this file to `wrangler.toml` and adjust the placeholder values for
# your deploy. The real `wrangler.toml` is gitignored because it embeds
# tenant-specific URLs and a session secret.
#
# Deploy: `npm run deploy` (from this directory) — runs
# `react-router build && wrangler deploy`.

name = "openinspection-web"
main = "./workers/app.ts"
compatibility_date = "2026-05-22"
compatibility_flags = ["nodejs_compat"]

[assets]
directory = "build/client"
binding = "ASSETS"

[vars]
# Public URL of the API Worker. Used by the SSR fallback when the
# Service Binding below isn't available (e.g. local dev).
API_URL = "https://openinspection-api.YOUR-ACCOUNT.workers.dev"
# Session cookie signing secret. Replace with a long random string for
# production deploys — `openssl rand -hex 32` works.
SESSION_SECRET = "change-me-to-a-long-random-string"

# Worker-to-Worker Service Binding to the API Worker. Zero-latency, no
# network hop. The `service` name MUST match the API Worker's `name` field
# in its wrangler.toml (defaults to `openinspection-api`).
[[services]]
binding = "API_WORKER"
service = "openinspection-api"

[observability]
enabled = true
