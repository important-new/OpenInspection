name = "openinspection-standalone"
main = "api/src/index.ts"
compatibility_date = "2024-09-23"
compatibility_flags = ["nodejs_compat"]
workers_dev = true
preview_urls = true

[triggers]
crons = ["* * * * *", "0 2 * * *", "0 * * * *"]

[assets]
directory = "./api/public"

[vars]
ENVIRONMENT = "production"
APP_MODE = "standalone"
# Turnstile site key — replace with your key from dash.cloudflare.com → Turnstile
# Default: Cloudflare's official always-pass test key (safe to use until you go live)
TURNSTILE_SITE_KEY = "1x00000000000000000000AA"

# ── SaaS environment override ──────────────────────────────────────────────
# Deploy with `wrangler deploy --env saas` to bring up a multi-tenant
# control-plane-fronted worker at app.<your-domain>. Pairs with
# apps/portal for billing + onboarding. Replace PORTAL_API_URL with your
# own portal worker that owns Stripe + onboarding workflows.
#
# IMPORTANT: wrangler does NOT inherit top-level resource bindings into
# env-specific overrides. Every binding must be redeclared under env.saas.*.
# The SaaS topology typically uses a single
# large D1 + a TENANT_CACHE KV partitioned by subdomain key prefix.
[env.saas]
name = "openinspection-saas"
[env.saas.vars]
ENVIRONMENT = "production"
APP_MODE = "saas"
SAAS_TOPOLOGY = "shared"
PORTAL_API_URL = "https://portal.your-domain.com"
TURNSTILE_SITE_KEY = "1x00000000000000000000AA"
[[env.saas.d1_databases]]
binding = "DB"
database_name = "openinspection-saas-db"
# Placeholder — create a separate D1 for the SaaS multi-tenant deployment
database_id = "00000000-0000-0000-0000-000000000000"
migrations_dir = "api/migrations"
[[env.saas.kv_namespaces]]
binding = "TENANT_CACHE"
id = "00000000000000000000000000000000"
[[env.saas.unsafe.bindings]]
type = "ratelimit"
name = "RATE_LIMITER"
namespace_id = "1003"
simple = { limit = 10, period = 60 }
[[env.saas.r2_buckets]]
binding = "PHOTOS"
bucket_name = "openinspection-saas-photos"
[[env.saas.r2_buckets]]
binding = "REPORTS"
bucket_name = "openinspection-saas-reports"
[env.saas.browser]
binding = "BROWSER"
[[env.saas.workflows]]
binding = "SIGN_COMPLETION_WORKFLOW"
name = "sign-completion-workflow-saas"
class_name = "SignCompletionWorkflow"
# Design System 0520 subsystem B — presence DOs mirrored into saas env.
[[env.saas.durable_objects.bindings]]
name       = "INSPECTION_PRESENCE"
class_name = "InspectionPresenceDO"
[[env.saas.durable_objects.bindings]]
name       = "TENANT_PRESENCE"
class_name = "TenantPresenceDO"
[[env.saas.migrations]]
tag = "v1"
new_classes = ["InspectionPresenceDO", "TenantPresenceDO"]

# ── Secrets — set via: wrangler secret put SECRET_NAME ──────────────────────
# Run `npm run setup:cloudflare` to be prompted for each one interactively.
#
# JWT_SECRET              — Required. HS256 signing key (any long random string)
# RESEND_API_KEY          — Optional. Resend.com API key for email delivery
# SENDER_EMAIL            — Optional. Verified sender address, e.g. "Reports <reports@yourdomain.com>"
# GEMINI_API_KEY          — Optional. Google Gemini API key for AI comment assist
# TURNSTILE_SECRET_KEY    — Optional. Server-side Turnstile key (skipped if absent)
# GOOGLE_CLIENT_ID        — Optional. Google Calendar OAuth client ID
# GOOGLE_CLIENT_SECRET    — Optional. Google Calendar OAuth client secret
# GOOGLE_PLACES_API_KEY   — Optional. Powers address autocomplete on /book + new-inspection wizard
# ESTATED_API_KEY         — Optional. Sprint 3 S3-1 — public-records auto-fill for Property Facts.
#                           Without it, /api/inspections/:id/property-facts/autofill returns
#                           { data: null, reason: 'NO_API_KEY' } and the UI prompts manual entry.
# QBO_CLIENT_ID          — Optional. Intuit app client ID (from developer.intuit.com)
# QBO_CLIENT_SECRET      — Optional. Intuit app client secret
# QBO_WEBHOOK_SECRET     — Optional. Webhook verifier token from Intuit Developer Portal

# ── Cloudflare resource bindings ─────────────────────────────────────────────
# These IDs are populated automatically by `npm run setup:cloudflare`.
# The Cloudflare Deploy Button will also handle database and KV creation.

[[d1_databases]]
binding = "DB"
database_name = "openinspection-standalone-db"
# Placeholder — `npm run setup:cloudflare` substitutes your real D1 ID
database_id = "00000000-0000-0000-0000-000000000000"
migrations_dir = "api/migrations"

[[kv_namespaces]]
binding = "TENANT_CACHE"
# Placeholder — `npm run setup:cloudflare` substitutes your real KV namespace ID
id = "00000000000000000000000000000000"

[[unsafe.bindings]]
type = "ratelimit"
name = "RATE_LIMITER"
namespace_id = "1001"
simple = { limit = 10, period = 60 }

[observability]
enabled = true

[[r2_buckets]]
binding = "PHOTOS"
bucket_name = "openinspection-standalone-photos"

# Spec 5A — Report PDF Pipeline. Stores Summary + Full Report PDFs
# pre-rendered at publish time, served via signed URLs to client viewer.
# Pattern mirrors Spectora's S3-based PDF distribution (see
# docs/competitors/07_spectora_analysis.md F.3). Uses BROWSER binding
# below to render report HTML -> PDF.
[[r2_buckets]]
binding = "REPORTS"
bucket_name = "openinspection-standalone-reports"

# Cloudflare Browser Rendering API — used by src/lib/pdf.ts to render
# /report/:id into a PDF for email delivery. Beta as of 2026-05; free tier
# 1000 requests/day on Workers Paid plan ($5/mo). If the binding is absent
# at runtime, src/api/inspections.ts falls back to text-only email.
[browser]
binding = "BROWSER"

# Spec 5H P1 — Sign-completion async pipeline (5 steps):
# 1. Render canonical signed.pdf via Browser Rendering -> R2
# 2. Render Certificate of Completion PDF -> R2
# 3. Build evidence.zip (signed.pdf + cert.pdf + audit-trail.json + public-key.pem) -> R2
# 4. Append 'workflow.complete' to esign_audit_logs (chain extension)
# 5. Email both parties via Resend
[[workflows]]
binding = "SIGN_COMPLETION_WORKFLOW"
name = "sign-completion-workflow"
class_name = "SignCompletionWorkflow"

# ── Design System 0520 subsystem B — multi-inspector presence (phase 2) ───
# Two Durable Object classes, both using the WebSocket Hibernation API.
# InspectionPresenceDO scopes per inspection id; TenantPresenceDO aggregates
# rosters across the tenant for the dashboard TeamStrip. Standalone single-
# inspector profiles can leave the bindings absent — routes feature-detect.
[[durable_objects.bindings]]
name       = "INSPECTION_PRESENCE"
class_name = "InspectionPresenceDO"

[[durable_objects.bindings]]
name       = "TENANT_PRESENCE"
class_name = "TenantPresenceDO"

[[migrations]]
tag = "v1"
new_classes = ["InspectionPresenceDO", "TenantPresenceDO"]
