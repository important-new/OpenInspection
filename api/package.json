{
  "name": "@core/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8788",
    "deploy": "node ../scripts/gen-version.js && npx wrangler d1 migrations apply DB --remote && npx wrangler deploy",
    "deploy:saas": "npx wrangler d1 migrations apply DB --remote -c wrangler.saas.toml && npx wrangler deploy -c wrangler.saas.toml",
    "type-check": "npx -p typescript tsc --noEmit",
    "test:unit": "vitest run --config vitest.config.ts",
    "db:migrate": "npx wrangler d1 migrations apply DB --local"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.2",
    "hono": "^4.12.18",
    "node-diff3": "^3.1.2",
    "otpauth": "^9.5.1",
    "qrcode": "^1.5.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.2",
    "@hono/zod-openapi": "^1.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.7",
    "happy-dom": "^20.9.0",
    "miniflare": "^4.20260405.0",
    "ts-morph": "^28.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3",
    "wrangler": "^4.52.1"
  }
}
