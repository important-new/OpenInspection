{
  "name": "openinspection",
  "version": "1.0.0-rc.1",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/InspectorHub/OpenInspection.git"
  },
  "homepage": "https://inspectorhub.io",
  "bugs": {
    "url": "https://github.com/InspectorHub/OpenInspection/issues"
  },
  "scripts": {
    "dev": "concurrently --kill-others \"wrangler dev --port 8788\" \"npx tailwindcss -c api/tailwind.config.js -i api/src/styles/input.css -o api/public/styles.css --watch\"",
    "vendor:copy": "node scripts/vendor-copy.js",
    "build": "npm run vendor:copy && npm run css:build && tsc",
    "gen-version": "node scripts/gen-version.js",
    "deploy": "npm run deploy:standalone",
    "deploy:api": "npm run deploy:api:standalone",
    "deploy:web": "npm run deploy:web:standalone",
    "deploy:standalone": "npm run deploy:api:standalone && npm run deploy:web:standalone",
    "deploy:saas": "npm run deploy:api:saas && npm run deploy:web:saas",
    "deploy:api:standalone": "node scripts/gen-version.js && npx wrangler d1 migrations apply DB --remote -c wrangler.standalone.toml && npm run css:build && npx wrangler deploy -c wrangler.standalone.toml",
    "deploy:api:saas": "node scripts/gen-version.js && npx wrangler d1 migrations apply DB --remote -c wrangler.saas.toml && npm run css:build && npx wrangler deploy -c wrangler.saas.toml",
    "deploy:web:standalone": "cd frontend && npx react-router build && npx wrangler deploy",
    "deploy:web:saas": "cd frontend && npx react-router build && npx wrangler deploy --env saas",
    "setup:cloudflare": "node scripts/setup-cloudflare.js",
    "setup:local": "node scripts/setup-cloudflare.js --local",
    "teardown:cloudflare": "node scripts/teardown-cloudflare.js",
    "teardown:local": "node scripts/teardown-cloudflare.js --local --force",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js",
    "rotate:jwt": "node scripts/rotate-jwt-keys.js",
    "css:build": "npx tailwindcss -c api/tailwind.config.js -i api/src/styles/input.css -o api/public/styles.css --minify",
    "css:watch": "npx tailwindcss -c api/tailwind.config.js -i api/src/styles/input.css -o api/public/styles.css --watch",
    "db:migrate": "npx wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "npx wrangler d1 migrations apply DB --remote",
    "seed:test-user": "node scripts/seed-test-user.mjs",
    "merge-assets": "node scripts/merge-assets.mjs",
    "dev:combined": "npm --prefix frontend run build && npm run merge-assets && npx wrangler d1 migrations apply DB --local -c wrangler.combined.toml && npm run seed:test-user && npx wrangler dev -c wrangler.combined.toml --port 8787 --local",
    "test:unit": "vitest run --config api/vitest.config.ts",
    "type-check": "npx -p typescript tsc --noEmit -p api/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "security-scan": "npm audit --audit-level=high",
    "seed:comments": "node scripts/seed-comments.js --local",
    "seed:comments:remote": "node scripts/seed-comments.js",
    "seed:recommendations": "node scripts/seed-recommendations.js --local",
    "seed:recommendations:remote": "node scripts/seed-recommendations.js",
    "seed:rating-systems": "node scripts/seed-rating-systems.js --local",
    "seed:rating-systems:remote": "node scripts/seed-rating-systems.js",
    "seed:marketplace": "node scripts/seed-marketplace.js --local",
    "seed:marketplace:remote": "node scripts/seed-marketplace.js",
    "prepare": "husky"
  },
  "dependencies": {
    "dexie": "^4.0.10",
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.2",
    "hono": "^4.12.18",
    "node-diff3": "^3.1.2",
    "otpauth": "^9.5.1",
    "qrcode": "^1.5.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.2",
    "@eslint/js": "^9.39.4",
    "@fontsource/bricolage-grotesque": "^5.2.10",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@hono/zod-openapi": "^1.2.4",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "better-sqlite3": "^12.8.0",
    "chart.js": "^4.5.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "fake-indexeddb": "^6.0.0",
    "flatpickr": "^4.6.13",
    "globals": "^17.4.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "konva": "^10.2.5",
    "lint-staged": "^16.4.0",
    "miniflare": "^4.20260405.0",
    "quill": "^2.0.3",
    "sortablejs": "^1.15.7",
    "swagger-ui-dist": "^5.32.5",
    "tailwindcss": "^3.4.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.3",
    "wrangler": "^4.95.0"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": []
  }
}
