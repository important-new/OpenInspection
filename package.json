{
  "name": "openinspection",
  "version": "1.0.0-rc.1",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/InspectorHub/OpenInspection.git"
  },
  "homepage": "https://inspectorhub.io",
  "bugs": {
    "url": "https://github.com/InspectorHub/OpenInspection/issues"
  },
  "scripts": {
    "dev": "npm run build && wrangler dev -c build/server/wrangler.json --persist-to .wrangler/state",
    "dev:hmr": "npm run vendor:copy && react-router dev",
    "build": "npm run vendor:copy && node scripts/gen-version.js && react-router build",
    "preview": "npm run build && wrangler dev -c build/server/wrangler.json --persist-to .wrangler/state",
    "deploy": "npm run build && wrangler deploy -c wrangler.jsonc",
    "vendor:copy": "node scripts/vendor-copy.js",
    "gen-version": "node scripts/gen-version.js",
    "type-check": "react-router typegen && node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit && node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc -p tsconfig.api.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "security-scan": "npm audit --audit-level=high",
    "test:unit": "vitest run --config vitest.api.config.ts",
    "test:web": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "db:migrate": "wrangler d1 migrations apply DB --local -c wrangler.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote -c wrangler.jsonc",
    "db:check": "node scripts/verify-migration-equivalence.mjs",
    "db:generate": "drizzle-kit generate",
    "seed:test-user": "node scripts/seed-test-user.mjs",
    "setup:cloudflare": "node scripts/setup-cloudflare.js",
    "setup:local": "node scripts/setup-cloudflare.js --local",
    "teardown:cloudflare": "node scripts/teardown-cloudflare.js",
    "teardown:local": "node scripts/teardown-cloudflare.js --local --force",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js",
    "rotate:jwt": "node scripts/rotate-jwt-keys.js",
    "seed:comments": "node scripts/seed-comments.js --local",
    "seed:comments:remote": "node scripts/seed-comments.js",
    "seed:recommendations": "node scripts/seed-recommendations.js --local",
    "seed:recommendations:remote": "node scripts/seed-recommendations.js",
    "seed:rating-systems": "node scripts/seed-rating-systems.js --local",
    "seed:rating-systems:remote": "node scripts/seed-rating-systems.js",
    "seed:marketplace": "node scripts/seed-marketplace.js --local",
    "seed:marketplace:remote": "node scripts/seed-marketplace.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@conform-to/react": "^1.19.3",
    "@conform-to/zod": "^1.19.3",
    "@react-router/cloudflare": "^7.6.0",
    "dexie": "^4.0.10",
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.3",
    "hono": "^4.12.18",
    "isbot": "^5.1.0",
    "node-diff3": "^3.1.2",
    "otpauth": "^9.5.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/vitest-pool-workers": "^0.14.2",
    "@eslint/js": "^9.39.4",
    "@fontsource/bricolage-grotesque": "^5.2.10",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@hono/zod-openapi": "^1.2.4",
    "@playwright/test": "^1.58.2",
    "@react-router/dev": "^7.6.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "better-sqlite3": "^12.8.0",
    "chart.js": "^4.5.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "fake-indexeddb": "^6.0.0",
    "flatpickr": "^4.6.13",
    "globals": "^17.4.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "konva": "^10.2.5",
    "lint-staged": "^16.4.0",
    "miniflare": "^4.20260405.0",
    "quill": "^2.0.3",
    "sortablejs": "^1.15.7",
    "swagger-ui-dist": "^5.32.5",
    "tailwindcss": "^4.1.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.3.0",
    "vitest": "^4.1.3",
    "wrangler": "^4.95.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": []
  }
}
