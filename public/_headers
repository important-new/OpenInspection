# Fingerprinted Vite build output — safe to cache forever.
# Stops the per-request revalidation round-trip that delays CSS/JS paint.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static assets with stable URLs — short cache + revalidation.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=604800

/logo.svg
  Cache-Control: public, max-age=604800
