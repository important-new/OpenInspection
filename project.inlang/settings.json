{
  "$schema": "https://inlang.com/schema/project-settings",
  "baseLocale": "en",
  "locales": [
    "en",
    "es-419"
  ],
  "modules": [
    "./node_modules/@inlang/plugin-message-format/dist/index.js"
  ],
  "plugin.inlang.messageFormat": {
    "pathPattern": [
      "./messages/{locale}/auth.json",
      "./messages/{locale}/common.json",
      "./messages/{locale}/nav.json",
      "./messages/{locale}/inspections.json",
      "./messages/{locale}/settings.json",
      "./messages/{locale}/settings-catalog.json",
      "./messages/{locale}/settings-integrations.json",
      "./messages/{locale}/settings-components.json",
      "./messages/{locale}/booking.json",
      "./messages/{locale}/calendar.json",
      "./messages/{locale}/contacts.json",
      "./messages/{locale}/templates.json",
      "./messages/{locale}/editor.json",
      "./messages/{locale}/editor-4.json",
      "./messages/{locale}/editor-3.json",
      "./messages/{locale}/editor-2.json",
      "./messages/{locale}/library.json",
      "./messages/{locale}/reports.json",
      "./messages/{locale}/metrics.json",
      "./messages/{locale}/public.json",
      "./messages/{locale}/media.json",
      "./messages/{locale}/components.json",
      "./messages/{locale}/checkout.json",
      "./messages/{locale}/labels.json",
      "./messages/{locale}/helpers.json",
      "./messages/{locale}/misc.json",
      "./messages/{locale}/pca-report.json",
      "./messages/{locale}/validation.json"
    ]
  }
}
